# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development

# fatal | error | warn | info | debug | trace
# info = quiet steady state. debug = your own debug logs. SQL logging is
# controlled separately by LOG_SQL below.
LOG_LEVEL=info

# Set true to dump every Drizzle SQL query. Independent of LOG_LEVEL. Very
# noisy — leave false unless actively debugging a query.
LOG_SQL=false

PORT=3000
HOST=0.0.0.0

# Public base URL of the API (used in magic-link emails).
# Local dev: http://localhost:3000
# Production: https://api.sansasakay.example
PUBLIC_API_URL=http://localhost:3000

# Public base URL of the web/landing app (used as the magic-link redirect target).
# Local dev: http://localhost:3001
# Production: https://sansasakay.example
PUBLIC_WEB_URL=http://localhost:3001

# ─── Database ────────────────────────────────────────────────────────────────
# In docker-compose this resolves to the `postgres` service.
DATABASE_URL=postgres://sakay:sakay@postgres:5432/sakay

# ─── Auth ────────────────────────────────────────────────────────────────────
# Min 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars
JWT_ISSUER=sakay-api
JWT_TTL_SECONDS=2592000

# Magic-link tokens are short-lived.
MAGIC_LINK_TTL_SECONDS=600

# ─── Email (SES in prod, Mailpit SMTP in dev) ────────────────────────────────
# In dev the Mailpit container catches all outgoing mail; SES creds are unused.
EMAIL_PROVIDER=mailpit
EMAIL_FROM="San Sasakay <no-reply@sansasakay.example>"

# Mailpit SMTP (dev only)
SMTP_HOST=mailpit
SMTP_PORT=1025

# AWS SES (prod only — leave blank in dev)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── S3 backups (prod) ───────────────────────────────────────────────────────
S3_BACKUP_BUCKET=

# ─── Aggregator ──────────────────────────────────────────────────────────────
AGGREGATOR_TICK_SECONDS=10
REPORT_DECAY_START_MINUTES=30
REPORT_EXPIRY_MINUTES=45
