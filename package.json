{
  "name": "sakay-api",
  "version": "0.1.0",
  "description": "San Sasakay backend API. Crowdsourced real-time transit intelligence for Metro Manila.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/client-sqs": "^3.700.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/websocket": "^11.0.1",
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.28.1",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
